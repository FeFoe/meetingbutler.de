{
  "name": "meetingbutler",
  "version": "1.0.0",
  "description": "Email-to-calendar SaaS: automatically converts forwarded emails into calendar events",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@bull-board/api": "^5.18.0",
    "@bull-board/express": "^5.18.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^5.10.0",
    "@types/pdfkit": "^0.17.6",
    "bullmq": "^5.4.0",
    "express": "^4.18.3",
    "ical-generator": "^7.1.0",
    "imapflow": "^1.0.162",
    "luxon": "^3.4.4",
    "mailparser": "^3.7.0",
    "nest-winston": "^1.9.4",
    "nodemailer": "^8.0.5",
    "openai": "^4.33.0",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sanitize-filename": "^1.6.3",
    "uuid": "^9.0.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.1.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
